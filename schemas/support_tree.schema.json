{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/support_tree.schema.json",
  "title": "SupportTree",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "support_tree_version",
    "target_claim_id",
    "nodes",
    "edges"
  ],
  "$defs": {
    "json_value": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "boolean"
        },
        {
          "type": "number"
        },
        {
          "type": "string"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/json_value"
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "patternProperties": {
            "^.*$": {
              "$ref": "#/$defs/json_value"
            }
          }
        }
      ]
    },
    "evidence_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_id",
        "chunk_id",
        "offset_start",
        "offset_end",
        "text_sha256"
      ],
      "properties": {
        "source_id": {
          "type": "string",
          "minLength": 1
        },
        "chunk_id": {
          "type": "string",
          "minLength": 1
        },
        "offset_start": {
          "type": "integer",
          "minimum": 0
        },
        "offset_end": {
          "type": "integer",
          "minimum": 0
        },
        "text_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    },
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "claim_id",
        "subject",
        "predicate",
        "object",
        "polarity",
        "modality",
        "qualifiers",
        "evidence"
      ],
      "properties": {
        "claim_id": {
          "type": "string",
          "minLength": 1
        },
        "subject": {
          "type": "string",
          "minLength": 1
        },
        "predicate": {
          "type": "string",
          "minLength": 1
        },
        "object": {
          "type": "string",
          "minLength": 1
        },
        "polarity": {
          "type": "string",
          "enum": [
            "affirm",
            "deny"
          ]
        },
        "modality": {
          "type": "string",
          "enum": [
            "assert",
            "possible",
            "necessary"
          ]
        },
        "qualifiers": {
          "type": "object",
          "additionalProperties": false,
          "patternProperties": {
            "^.*$": {
              "$ref": "#/$defs/json_value"
            }
          }
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidence_ref"
          }
        }
      }
    },
    "proof_edge": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "from_id",
        "to_id",
        "type"
      ],
      "properties": {
        "from_id": {
          "type": "string",
          "minLength": 1
        },
        "to_id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "primitive_edge": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "from_id",
        "to_id",
        "type",
        "derived",
        "proof"
      ],
      "properties": {
        "from_id": {
          "type": "string",
          "minLength": 1
        },
        "to_id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "supports",
            "implies"
          ]
        },
        "derived": {
          "type": "boolean",
          "const": false
        },
        "proof": {
          "type": "null"
        }
      }
    },
    "derived_edge": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "from_id",
        "to_id",
        "type",
        "derived",
        "proof"
      ],
      "properties": {
        "from_id": {
          "type": "string",
          "minLength": 1
        },
        "to_id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "supports",
            "implies"
          ]
        },
        "derived": {
          "type": "boolean",
          "const": true
        },
        "proof": {
          "type": "array",
          "minItems": 2,
          "items": {
            "$ref": "#/$defs/proof_edge"
          }
        }
      }
    }
  },
  "properties": {
    "support_tree_version": {
      "type": "string",
      "minLength": 1
    },
    "target_claim_id": {
      "type": "string",
      "minLength": 1
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "claim_id",
          "claim"
        ],
        "properties": {
          "claim_id": {
            "type": "string",
            "minLength": 1
          },
          "claim": {
            "$ref": "#/$defs/claim"
          }
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "$ref": "#/$defs/primitive_edge"
          },
          {
            "$ref": "#/$defs/derived_edge"
          }
        ]
      }
    }
  }
}
