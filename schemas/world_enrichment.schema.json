{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/world_enrichment.schema.json",
  "title": "WorldEnrichment",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "events"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0"
    },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "event_id"
        ],
        "properties": {
          "event_id": {
            "type": "string",
            "pattern": "^event:[0-9a-f]{64}$"
          },
          "actors": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "objects": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "time": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "kind"
            ],
            "properties": {
                "kind": {
                  "type": "string",
                  "enum": [
                    "unknown",
                    "date",
                    "instant",
                    "datetime",
                    "relative"
                  ]
                },
              "value": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    }
  }
}
