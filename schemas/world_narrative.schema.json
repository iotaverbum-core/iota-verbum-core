{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/world_narrative.schema.json",
  "title": "WorldNarrative",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "narrative_version",
    "world_sha256",
    "text",
    "paragraphs"
  ],
  "$defs": {
    "evidence_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_id",
        "chunk_id",
        "offset_start",
        "offset_end",
        "text_sha256"
      ],
      "properties": {
        "source_id": {
          "type": "string",
          "minLength": 1
        },
        "chunk_id": {
          "type": "string",
          "minLength": 1
        },
        "offset_start": {
          "type": "integer",
          "minimum": 0
        },
        "offset_end": {
          "type": "integer",
          "minimum": 0
        },
        "text_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    },
    "json_value": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "boolean"
        },
        {
          "type": "number"
        },
        {
          "type": "string"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/json_value"
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "patternProperties": {
            "^.*$": {
              "$ref": "#/$defs/json_value"
            }
          }
        }
      ]
    },
    "receipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "ref"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "evidence",
            "conflict"
          ]
        },
        "ref": {
          "oneOf": [
            {
              "$ref": "#/$defs/evidence_ref"
            },
            {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "kind",
                "ref",
                "reason"
              ],
              "properties": {
                "kind": {
                  "type": "string",
                  "enum": [
                    "state_conflict",
                    "ordering_conflict"
                  ]
                },
                "ref": {
                  "type": "object",
                  "additionalProperties": false,
                  "patternProperties": {
                    "^.*$": {
                      "$ref": "#/$defs/json_value"
                    }
                  }
                },
                "reason": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          ]
        }
      }
    }
  },
  "properties": {
    "narrative_version": {
      "type": "string",
      "const": "1.0"
    },
    "world_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "text": {
      "type": "string"
    },
    "paragraphs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "pid",
          "title",
          "body",
          "receipts"
        ],
        "properties": {
          "pid": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "body": {
            "type": "string"
          },
          "receipts": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/receipt"
            }
          }
        }
      }
    }
  }
}
