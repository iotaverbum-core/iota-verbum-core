{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/repair_narrative_v2.schema.json",
  "title": "RepairNarrativeV2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "narrative_version",
    "mode",
    "text",
    "sections",
    "summary"
  ],
  "properties": {
    "narrative_version": {
      "type": "string",
      "const": "2.0"
    },
    "mode": {
      "type": "string",
      "enum": [
        "brief",
        "full"
      ]
    },
    "text": {
      "type": "string"
    },
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "title",
          "lines"
        ],
        "properties": {
          "title": {
            "type": "string"
          },
          "lines": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "plan_id",
        "base_verification",
        "action_count",
        "selected_action_id",
        "verification_old",
        "verification_new",
        "replay_ok"
      ],
      "properties": {
        "plan_id": {
          "type": "string",
          "pattern": "^plan:[0-9a-f]{64}$"
        },
        "base_verification": {
          "type": "string",
          "enum": [
            "VERIFIED_OK",
            "VERIFIED_FAIL",
            "VERIFIED_NEEDS_INFO"
          ]
        },
        "action_count": {
          "type": "integer",
          "minimum": 0
        },
        "selected_action_id": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "string",
              "pattern": "^act:[0-9a-f]{64}$"
            }
          ]
        },
        "verification_old": {
          "type": "string",
          "enum": [
            "VERIFIED_OK",
            "VERIFIED_FAIL",
            "VERIFIED_NEEDS_INFO"
          ]
        },
        "verification_new": {
          "type": "string",
          "enum": [
            "VERIFIED_OK",
            "VERIFIED_FAIL",
            "VERIFIED_NEEDS_INFO"
          ]
        },
        "replay_ok": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "boolean"
            }
          ]
        }
      }
    }
  }
}
