{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/repair_hints_narrative_v2.schema.json",
  "title": "RepairHintsNarrativeV2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "narrative_version",
    "verbosity",
    "text",
    "sections",
    "summary"
  ],
  "properties": {
    "narrative_version": {
      "type": "string",
      "const": "2.0"
    },
    "verbosity": {
      "type": "string",
      "enum": [
        "brief",
        "full"
      ]
    },
    "text": {
      "type": "string"
    },
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "title",
          "lines"
        ],
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1
          },
          "lines": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hint_count",
        "low_risk_count",
        "medium_risk_count",
        "high_risk_count"
      ],
      "properties": {
        "hint_count": {
          "type": "integer",
          "minimum": 0
        },
        "low_risk_count": {
          "type": "integer",
          "minimum": 0
        },
        "medium_risk_count": {
          "type": "integer",
          "minimum": 0
        },
        "high_risk_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
